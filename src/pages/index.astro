---
import Layout from '../layouts/Layout.astro';
import TileCalculator from '../components/TileCalculator.astro';
---

<Layout
  title="Дзеркальна плитка Київ — калькулятор панно онлайн"
  description="Калькулятор дзеркального панно онлайн. Введіть розміри стіни — отримайте варіанти розкрою та вартість. Дзеркальна плитка в Києві від виробника."
>
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__eyebrow">Дзеркальна плитка в Києві</p>
        <h1>Розкрийте простір<br />дзеркальним панно</h1>
        <p class="hero__desc">
          Виготовляємо та монтуємо дзеркальну плитку з фацетом. Розрахуйте вартість онлайн прямо зараз.
        </p>
        <div class="hero__actions">
          <a href="#calculator" class="btn btn--primary">Розрахувати вартість</a>
          <a href="/led-dzerkalo/" class="btn btn--outline">LED дзеркала</a>
        </div>
      </div>
      <div class="hero__badges">
        <div class="badge">
          <span class="badge__num">10+</span>
          <span class="badge__text">років досвіду</span>
        </div>
        <div class="badge">
          <span class="badge__num">500+</span>
          <span class="badge__text">виконаних проєктів</span>
        </div>
        <div class="badge">
          <span class="badge__num">3-7</span>
          <span class="badge__text">днів виготовлення</span>
        </div>
      </div>
    </div>
  </section>

  <div id="calculator">
    <TileCalculator />
  </div>

  <section class="section">
    <div class="container">
      <h2 class="section-heading">Чому обирають нас</h2>
      <div class="grid-4 advantages">
        <div class="advantage">
          <div class="advantage__icon">🏭</div>
          <h3>Власне виробництво</h3>
          <p>Виготовляємо плитку самостійно — без посередників і переплат.</p>
        </div>
        <div class="advantage">
          <div class="advantage__icon">📐</div>
          <h3>Точний розкрій</h3>
          <p>Автоматизований розрахунок кількості матеріалу — мінімум відходів.</p>
        </div>
        <div class="advantage">
          <div class="advantage__icon">🔧</div>
          <h3>Монтаж під ключ</h3>
          <p>Наша бригада встановить панно акуратно та швидко.</p>
        </div>
        <div class="advantage">
          <div class="advantage__icon">🚚</div>
          <h3>Доставка по Києву</h3>
          <p>Доставляємо в зручний для вас час у межах міста.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section section">
    <div class="container">
      <div class="cta-box">
        <div>
          <h2>Потрібна консультація?</h2>
          <p>Зв'яжіться з нами — безкоштовно підберемо оптимальний варіант для вашого простору.</p>
        </div>
        <div class="cta-box__actions">
          <a href="tel:+380995283637" class="btn btn--primary">📞 Зателефонувати</a>
          <a href="https://t.me/europlitka" target="_blank" class="btn btn--outline">Telegram</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(160deg, #080808 0%, #0f0f0f 60%, #0d0b06 100%);
    color: #fff;
    padding: 80px 0 72px;
    border-bottom: 1px solid rgba(201,168,76,0.12);
  }
  .hero__inner { display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center; }
  .hero__eyebrow {
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero__eyebrow::before { content: ''; display: inline-block; width: 28px; height: 1px; background: var(--gold); }
  .hero h1 { color: #fff; margin-bottom: 16px; }
  .hero__desc { color: #777; font-size: 1.05rem; max-width: 48ch; margin-bottom: 32px; line-height: 1.7; }
  .hero__actions { display: flex; gap: 12px; flex-wrap: wrap; }
  .hero__badges { display: flex; flex-direction: column; gap: 12px; }
  .badge {
    background: rgba(201,168,76,0.05);
    border: 1px solid rgba(201,168,76,0.18);
    border-radius: 10px;
    padding: 16px 24px;
    text-align: center;
    min-width: 130px;
  }
  .badge__num { display: block; font-size: 1.8rem; font-weight: 800; color: var(--gold); }
  .badge__text { font-size: 0.72rem; color: #555; text-transform: uppercase; letter-spacing: 0.1em; }

  .section-heading { margin-bottom: 36px; }

  .advantage {
    text-align: center;
    padding: 28px 20px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: border-color 0.25s;
  }
  .advantage:hover { border-color: rgba(201,168,76,0.3); }
  .advantage__icon { font-size: 2rem; margin-bottom: 14px; }
  .advantage h3 { margin-bottom: 8px; color: #ddd; }
  .advantage p { font-size: 0.88rem; color: var(--text-muted); }

  .cta-box {
    background: linear-gradient(135deg, #130f02 0%, #1c1608 100%);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 16px;
    padding: 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .cta-box h2 { color: #fff; margin-bottom: 8px; }
  .cta-box p { color: #777; max-width: 50ch; }
  .cta-box__actions { display: flex; gap: 12px; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__badges { flex-direction: row; flex-wrap: wrap; }
    .badge { flex: 1; min-width: 100px; }
    .cta-box { padding: 32px 24px; }
  }
</style>
