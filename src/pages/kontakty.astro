---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout title="Контакти" description="Контакти Євро Плитка. Телефон, email, адреса. Дзеркальна плитка та LED дзеркала в Києві.">
  <div class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Головна</a><span>›</span><span>Контакти</span></div>
      <h1>Контакти</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contacts-grid">
        <div class="contact-card">
          <div class="contact-card__icon">📞</div>
          <h3>Телефон</h3>
          <a href={`tel:${site.phone.tel}`}>{site.phone.display}</a>
        </div>
        <div class="contact-card">
          <div class="contact-card__icon">✉️</div>
          <h3>Email</h3>
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </div>
        <div class="contact-card">
          <div class="contact-card__icon">🕐</div>
          <h3>Графік роботи</h3>
          <p>{site.workingHours}</p>
        </div>
        <div class="contact-card">
          <div class="contact-card__icon">💬</div>
          <h3>Telegram</h3>
          <a href={site.social.telegram} target="_blank">Написати в Telegram</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contacts-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }
  .contact-card { padding: 28px 20px; border: 1.5px solid var(--border); border-radius: 12px; text-align: center; }
  .contact-card__icon { font-size: 2rem; margin-bottom: 12px; }
  .contact-card h3 { margin-bottom: 8px; font-size: 1rem; }
  .contact-card a { color: var(--green); font-weight: 600; }
  .contact-card a:hover { text-decoration: underline; }
  .contact-card p { color: var(--text-muted); }
  @media (max-width: 700px) { .contacts-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 400px) { .contacts-grid { grid-template-columns: 1fr; } }
</style>
