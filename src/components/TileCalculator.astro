---
import { tileCalcConfig } from '../data/site';
const cfg = JSON.stringify(tileCalcConfig);
---

<section class="calc-section section">
  <div class="container">
    <h2 class="calc-title">Калькулятор дзеркального панно</h2>
    <p class="calc-sub">Введіть розміри вашої стіни — отримайте варіанти розкрою та вартість</p>

    <div class="calc-inputs">
      <label class="calc-field">
        <span class="calc-field__icon">↔</span>
        <span class="calc-field__label">Ширина</span>
        <input type="number" id="wallW" value="1500" min="200" max="6000" step="10" />
        <span class="calc-field__unit">мм</span>
      </label>
      <label class="calc-field">
        <span class="calc-field__icon">↕</span>
        <span class="calc-field__label">Висота</span>
        <input type="number" id="wallH" value="2700" min="200" max="6000" step="10" />
        <span class="calc-field__unit">мм</span>
      </label>
      <label class="calc-field">
        <span class="calc-field__icon">◻</span>
        <span class="calc-field__label">Фацет</span>
        <select id="facet">
          <option value="0">0</option>
          <option value="5">5</option>
          <option value="10" selected>10</option>
          <option value="15">15</option>
          <option value="20">20</option>
        </select>
        <span class="calc-field__unit">мм</span>
      </label>
      <label class="calc-field calc-field--color">
        <span class="calc-field__icon">◉</span>
        <span class="calc-field__label">Колір</span>
        <select id="color">
          <option value="silver">Серебро</option>
          <option value="bronze">Бронза</option>
          <option value="graphite">Графіт</option>
        </select>
        <span class="calc-field__swatch" id="colorSwatch"></span>
      </label>
    </div>

    <div class="calc-results" id="calcResults">
      <div class="calc-variant" id="variant2">
        <div class="variant-heading">
          <span class="variant-fig">Рис. 2</span>
          <span class="variant-type">квадрат</span>
        </div>
        <div class="variant-svg-wrap">
          <svg class="panel-svg" id="svg2" xmlns="http://www.w3.org/2000/svg"></svg>
        </div>
        <div class="variant-nav-row">
          <button class="variant-nav" id="prevVar2">‹</button>
          <span class="variant-counter" id="counter2"></span>
          <button class="variant-nav" id="nextVar2">›</button>
        </div>
        <div class="variant-dims" id="dims2"></div>
        <div class="variant-info" id="info2"></div>
        <button class="btn btn--primary calc-order-btn" data-variant="2">🛒 Замовити</button>
      </div>

      <div class="calc-variant" id="variant3">
        <div class="variant-heading">
          <span class="variant-fig">Рис. 3</span>
          <span class="variant-type">ромб</span>
        </div>
        <div class="variant-svg-wrap">
          <svg class="panel-svg" id="svg3" xmlns="http://www.w3.org/2000/svg"></svg>
        </div>
        <div class="variant-nav-row">
          <button class="variant-nav" id="prevVar3">‹</button>
          <span class="variant-counter" id="counter3"></span>
          <button class="variant-nav" id="nextVar3">›</button>
        </div>
        <div class="variant-dims" id="dims3"></div>
        <div class="variant-info" id="info3"></div>
        <button class="btn btn--primary calc-order-btn" data-variant="3">🛒 Замовити</button>
      </div>
    </div>

    <!-- Модальне вікно замовлення -->
    <div class="order-modal" id="orderModal">
      <div class="order-modal__box">
        <button class="order-modal__close" id="closeModal">✕</button>
        <h3 id="modalTitle">Зеркальне панно</h3>
        <table class="order-table" id="orderTable"></table>
        <div class="order-modal__form">
          <p class="order-modal__want-cheaper">
            <label>
              <input type="checkbox" id="wantCheaper" />
              Хочу дешевше! <span class="info-icon" title="Ми підберемо оптимальний варіант для вашого бюджету">ℹ</span>
            </label>
          </p>
          <input type="text" placeholder="Ім'я та Прізвище" class="order-modal__input" id="modalName" />
          <input type="tel" placeholder="Телефон" class="order-modal__input" id="modalPhone" />
          <button class="btn btn--primary" id="submitOrder" style="width:100%">Відправити замовлення</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ cfg }}>
const CONFIG = JSON.parse(cfg);

// ---- Математика ----
function calcVariants(W, H, facet, color) {
  const pricePerM2 = color === 'silver' ? CONFIG.silverPrice : CONFIG.colorPrice;
  const variants = [];

  // Перебираємо можливу кількість плиток по ширині
  for (let N = 1; N <= 20; N++) {
    const d1 = W / N; // горизонтальна діагональ ромба

    // Рис. 2: квадратний ромб (d1 = d2)
    const d2_fig2 = d1;
    const rowPitch2 = d1 / 2;
    const rows2 = Math.floor(H / rowPitch2);
    const actualH2 = rows2 * rowPitch2;
    if (actualH2 < 200) continue;
    const tileSize2 = Math.round(Math.sqrt(d1 * d1 + d2_fig2 * d2_fig2) / 2);
    if (tileSize2 < 200) continue; // мінімум 200мм

    // Рис. 3: прямокутний ромб (висота точна)
    const M3 = Math.round(H / d1);
    if (M3 < 1) continue;
    const d2_fig3 = H / M3;
    const tileSize3 = Math.round(Math.sqrt(d1 * d1 + d2_fig3 * d2_fig3) / 2);

    // Калькуляція ціни
    const area2 = (W * actualH2) / 1e6;
    const area3 = (W * H) / 1e6;

    // Фактор розмітки залежить від розміру плитки (калібровано)
    const tileRatio2 = (tileSize2 - 177) / 177;
    const tileRatio3 = (tileSize3 - 177) / 177;
    const markup2 = Math.max(1.0, CONFIG.fig2Markup - tileRatio2 * 0.163);
    const markup3 = Math.max(1.0, CONFIG.fig3Markup - tileRatio3 * 0.171);

    const basePrice2 = Math.round(area2 * pricePerM2 * markup2);
    const finalPrice2 = Math.round(basePrice2 * (1 - CONFIG.fig2Discount));

    const basePrice3 = Math.round(area3 * pricePerM2 * markup3);
    const finalPrice3 = Math.round(basePrice3 * (1 - CONFIG.fig3Discount));

    // Кількість плиток (для інформації в модалці)
    const tileArea2 = (tileSize2 * tileSize2) / 1e6;
    const tileArea3 = (tileSize3 * tileSize3) / 1e6;
    const totalTiles2 = Math.ceil(area2 / tileArea2);
    const totalTiles3 = Math.ceil(area3 / tileArea3);
    const fullTiles2 = Math.round(totalTiles2 * 0.87);
    const triTiles2 = Math.round(totalTiles2 * 0.12);
    const fullTiles3 = Math.round(totalTiles3 * 0.87);
    const triTiles3 = Math.round(totalTiles3 * 0.12);

    variants.push({
      N,
      fig2: {
        d1: Math.round(d1), d2: Math.round(d2_fig2),
        tileSize: tileSize2,
        actualH: Math.round(actualH2),
        area: area2,
        basePrice: basePrice2,
        finalPrice: finalPrice2,
        discount: CONFIG.fig2Discount,
        fullTiles: fullTiles2, triTiles: triTiles2,
        tilePrice: Math.round(tileSize2 * tileSize2 / 1e6 * pricePerM2 * markup2),
        triPrice: Math.round(tileSize2 * tileSize2 / 1e6 * pricePerM2 * markup2 * CONFIG.triangleCoef),
      },
      fig3: {
        d1: Math.round(d1), d2: Math.round(d2_fig3),
        tileSize: tileSize3,
        actualH: H,
        area: area3,
        basePrice: basePrice3,
        finalPrice: finalPrice3,
        discount: CONFIG.fig3Discount,
        fullTiles: fullTiles3, triTiles: triTiles3,
        tilePrice: Math.round(tileSize3 * tileSize3 / 1e6 * pricePerM2 * markup3),
        triPrice: Math.round(tileSize3 * tileSize3 / 1e6 * pricePerM2 * markup3 * CONFIG.triangleCoef),
      },
    });
  }
  return variants;
}

// ---- SVG ----
function drawPanel(svgEl, W, H, d1, d2) {
  // Фіксований viewport, пропорційний стіні, але max висота 420
  const MAX_W = 260, MAX_H = 420;
  const ratio = H / W;
  let pW, pH;
  if (ratio > MAX_H / MAX_W) {
    pH = MAX_H; pW = Math.round(pH / ratio);
  } else {
    pW = MAX_W; pH = Math.round(pW * ratio);
  }

  const margin = 26;
  const VW = pW + margin + 6;
  const VH = pH + margin + 6;
  svgEl.setAttribute('viewBox', `0 0 ${VW} ${VH}`);
  svgEl.style.height = VH + 'px';

  const ox = 4, oy = margin;

  const scaleX = pW / W;
  const scaleY = pH / H;
  const cellW = d1 * scaleX;
  const cellH = d2 * scaleY;

  let paths = '';
  const cols = Math.ceil(W / d1) + 2;
  const rows = Math.ceil(H / (d2 / 2)) + 2;
  for (let r = -1; r <= rows; r++) {
    for (let c = -1; c <= cols; c++) {
      const cx = ox + (c + (r % 2 === 0 ? 0.5 : 0)) * cellW;
      const cy = oy + r * (cellH / 2);
      const pts = [
        [cx, cy - cellH / 2],
        [cx + cellW / 2, cy],
        [cx, cy + cellH / 2],
        [cx - cellW / 2, cy],
      ];
      const dp = `M${pts[0][0].toFixed(1)},${pts[0][1].toFixed(1)} L${pts[1][0].toFixed(1)},${pts[1][1].toFixed(1)} L${pts[2][0].toFixed(1)},${pts[2][1].toFixed(1)} L${pts[3][0].toFixed(1)},${pts[3][1].toFixed(1)} Z`;
      paths += `<path d="${dp}" fill="#2a2520" stroke="#4a4030" stroke-width="1" />`;
    }
  }

  const clipId = `clip-${Math.random().toString(36).slice(2)}`;
  const fs = 9;
  svgEl.innerHTML = `
    <defs>
      <clipPath id="${clipId}">
        <rect x="${ox}" y="${oy}" width="${pW}" height="${pH}" />
      </clipPath>
    </defs>
    <rect x="${ox}" y="${oy}" width="${pW}" height="${pH}" fill="#1a1610" />
    <g clip-path="url(#${clipId})">${paths}</g>
    <rect x="${ox}" y="${oy}" width="${pW}" height="${pH}" fill="none" stroke="#c9a84c" stroke-width="1.5" />
    <!-- ширина: лінія зверху -->
    <line x1="${ox}" y1="${oy - 8}" x2="${ox + pW}" y2="${oy - 8}" stroke="#c9a84c" stroke-width="1.2" />
    <line x1="${ox}" y1="${oy - 12}" x2="${ox}" y2="${oy - 4}" stroke="#c9a84c" stroke-width="1.2" />
    <line x1="${ox + pW}" y1="${oy - 12}" x2="${ox + pW}" y2="${oy - 4}" stroke="#c9a84c" stroke-width="1.2" />
    <text x="${ox + pW / 2}" y="${oy - 11}" text-anchor="middle" font-size="${fs}" fill="#c9a84c" font-family="Arial,sans-serif" font-weight="700">${W} мм</text>
    <!-- висота: лінія справа -->
    <line x1="${ox + pW + 8}" y1="${oy}" x2="${ox + pW + 8}" y2="${oy + pH}" stroke="#c9a84c" stroke-width="1.2" />
    <line x1="${ox + pW + 4}" y1="${oy}" x2="${ox + pW + 12}" y2="${oy}" stroke="#c9a84c" stroke-width="1.2" />
    <line x1="${ox + pW + 4}" y1="${oy + pH}" x2="${ox + pW + 12}" y2="${oy + pH}" stroke="#c9a84c" stroke-width="1.2" />
    <text x="${ox + pW + 11}" y="${oy + pH / 2}" text-anchor="middle" font-size="${fs}" fill="#c9a84c" font-family="Arial,sans-serif" font-weight="700" transform="rotate(90,${ox + pW + 11},${oy + pH / 2})">${H} мм</text>
  `;
}

// ---- Форматування ціни ----
function fmt(n) {
  return n.toLocaleString('uk-UA') + ' грн';
}
function fmtOld(n) {
  return `<s>${n.toLocaleString('uk-UA')} грн</s>`;
}

// ---- Рендер ----
let allVariants = [];
let idxes = [0, 0];

function defaultIndex(variants) {
  // Знаходимо перший варіант де tileSize <= 350мм (як старий сайт — починає з N=4)
  const idx = variants.findIndex(v => v.fig2.tileSize <= 350);
  return idx >= 0 ? idx : variants.length - 1;
}

function render() {
  const W = parseInt(document.getElementById('wallW').value) || 1500;
  const H = parseInt(document.getElementById('wallH').value) || 2700;
  const facet = parseInt(document.getElementById('facet').value);
  const color = document.getElementById('color').value;

  allVariants = calcVariants(W, H, facet, color);
  const def = defaultIndex(allVariants);
  idxes = [def, def];
  renderVariants(W, H);
}

function renderVariants(W, H) {
  if (!allVariants.length) return;

  const v2 = allVariants[Math.min(idxes[0], allVariants.length - 1)].fig2;
  const v3 = allVariants[Math.min(idxes[1], allVariants.length - 1)].fig3;

  // SVG
  drawPanel(document.getElementById('svg2'), W, v2.actualH, v2.d1, v2.d2);
  drawPanel(document.getElementById('svg3'), W, v3.actualH, v3.d1, v3.d2);

  // Розміри
  document.getElementById('dims2').innerHTML = `
    <span>Розмір плитки: <b>${v2.tileSize}×${v2.tileSize} мм</b></span>
    <span>Діагоналі: <b>${v2.d1}×${v2.d2} мм</b></span>
  `;
  document.getElementById('dims3').innerHTML = `
    <span>Розмір плитки: <b>${v3.tileSize}×${v3.tileSize} мм</b></span>
    <span>Діагоналі: <b>${v3.d1}×${v3.d2} мм</b></span>
  `;

  // Ціна
  document.getElementById('info2').innerHTML = `
    <div class="price-line">${fmtOld(v2.basePrice)} <span class="price-final">${fmt(v2.finalPrice)}</span></div>
    <div class="discount-badge">Знижка -${Math.round(v2.discount * 100)}%</div>
  `;
  document.getElementById('info3').innerHTML = `
    <div class="price-line">${fmtOld(v3.basePrice)} <span class="price-final">${fmt(v3.finalPrice)}</span></div>
    <div class="discount-badge discount-badge--big">Знижка -${Math.round(v3.discount * 100)}%</div>
  `;

  // Лічильник варіантів
  const total = allVariants.length;
  document.getElementById('counter2').textContent = `${idxes[0] + 1} / ${total}`;
  document.getElementById('counter3').textContent = `${idxes[1] + 1} / ${total}`;

  // Збережемо для модалки
  document.getElementById('variant2').dataset.v = JSON.stringify(v2);
  document.getElementById('variant3').dataset.v = JSON.stringify(v3);
}

function navigate(figIdx, dir) {
  const W = parseInt(document.getElementById('wallW').value) || 1500;
  const H = parseInt(document.getElementById('wallH').value) || 2700;
  idxes[figIdx] = Math.max(0, Math.min(allVariants.length - 1, idxes[figIdx] + dir));
  renderVariants(W, H);
}

// ---- Модалка ----
function openModal(variantNum) {
  const elId = variantNum === '2' ? 'variant2' : 'variant3';
  const v = JSON.parse(document.getElementById(elId).dataset.v || '{}');
  const W = parseInt(document.getElementById('wallW').value) || 1500;
  const colorSel = document.getElementById('color');
  const colorLabel = colorSel.options[colorSel.selectedIndex].text;

  document.getElementById('modalTitle').textContent =
    `Дзеркальне панно ${W}×${v.actualH} мм`;

  const rows = [
    ['◻', `${v.tileSize}×${v.tileSize} мм`, `${v.d1 > 0 ? v.d1 : '-'} мм`, colorLabel, v.fullTiles + ' шт.', fmt(Math.round(v.fullTiles * v.tilePrice))],
    ['◺', `${v.tileSize}×${v.tileSize} мм`, `${v.d1 > 0 ? v.d1 : '-'} мм`, colorLabel, v.triTiles + ' шт.', fmt(Math.round(v.triTiles * v.triPrice))],
  ];

  document.getElementById('orderTable').innerHTML = `
    <thead>
      <tr><th>Форма</th><th>Розмір</th><th>Фацет</th><th>Колір</th><th>К-во</th><th>Ціна</th></tr>
    </thead>
    <tbody>
      ${rows.map(r => `<tr>${r.map(c => `<td>${c}</td>`).join('')}</tr>`).join('')}
      <tr class="order-total">
        <td colspan="4">Скидка -${Math.round(v.discount * 100)}%</td>
        <td colspan="2"><b>${fmt(v.finalPrice)}</b></td>
      </tr>
    </tbody>
  `;

  document.getElementById('orderModal').classList.add('open');
}

// ---- Ініціалізація ----
document.addEventListener('DOMContentLoaded', () => {
  render();

  let debounceTimer;
  ['wallW', 'wallH'].forEach(id => {
    document.getElementById(id).addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(render, 300);
    });
    document.getElementById(id).addEventListener('change', render);
  });
  ['facet', 'color'].forEach(id =>
    document.getElementById(id).addEventListener('change', render)
  );

  document.getElementById('prevVar2').addEventListener('click', () => navigate(0, -1));
  document.getElementById('nextVar2').addEventListener('click', () => navigate(0, 1));
  document.getElementById('prevVar3').addEventListener('click', () => navigate(1, -1));
  document.getElementById('nextVar3').addEventListener('click', () => navigate(1, 1));

  document.querySelectorAll('.calc-order-btn').forEach(btn => {
    btn.addEventListener('click', () => openModal(btn.dataset.variant));
  });

  document.getElementById('closeModal').addEventListener('click', () =>
    document.getElementById('orderModal').classList.remove('open')
  );
  document.getElementById('orderModal').addEventListener('click', (e) => {
    if (e.target === document.getElementById('orderModal'))
      document.getElementById('orderModal').classList.remove('open');
  });

  // Кольоровий зразок
  const swatchColors = { silver: '#c0c0c0', bronze: '#cd7f32', graphite: '#555' };
  const colorSel = document.getElementById('color');
  const swatch = document.getElementById('colorSwatch');
  const updateSwatch = () => { swatch.style.background = swatchColors[colorSel.value]; };
  colorSel.addEventListener('change', updateSwatch);
  updateSwatch();

  document.getElementById('submitOrder').addEventListener('click', () => {
    const name = document.getElementById('modalName').value.trim();
    const phone = document.getElementById('modalPhone').value.trim();
    if (!name || !phone) { alert('Будь ласка, вкажіть ім\'я та телефон'); return; }
    alert('Дякуємо! Ми зв\'яжемося з вами найближчим часом.');
    document.getElementById('orderModal').classList.remove('open');
  });
});
</script>

<style>
  .calc-section { background: var(--bg-gray); }
  .calc-title { margin-bottom: 6px; color: var(--text); }
  .calc-sub { color: var(--text-muted); margin-bottom: 32px; }

  .calc-inputs {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .calc-field {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 14px;
    cursor: pointer;
    transition: border-color 0.2s;
    min-width: 180px;
    flex: 1;
  }
  .calc-field:focus-within { border-color: var(--gold); }
  .calc-field__icon { font-size: 1rem; color: var(--gold); }
  .calc-field__label { font-size: 0.82rem; color: var(--text-muted); white-space: nowrap; }
  .calc-field input, .calc-field select {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 600;
    background: transparent;
    color: var(--text);
    min-width: 60px;
  }
  .calc-field select option { background: #1e1e1e; color: var(--text); }
  .calc-field__unit { font-size: 0.82rem; color: var(--text-muted); }
  .calc-field__swatch {
    width: 20px; height: 20px;
    border-radius: 50%;
    border: 1px solid #444;
    flex-shrink: 0;
  }

  .calc-results {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .calc-variant {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s;
  }
  .calc-variant:hover { border-color: var(--border-gold); }

  .variant-heading {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 4px;
  }
  .variant-fig { font-weight: 700; font-size: 1.1rem; color: var(--text); }
  .variant-type { font-size: 0.78rem; color: var(--gold); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; }

  .variant-nav-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 4px 0;
  }
  .variant-counter { font-size: 0.88rem; color: var(--text-muted); font-weight: 600; min-width: 40px; text-align: center; }
  .variant-nav {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    width: 36px; height: 36px;
    font-size: 1.4rem;
    cursor: pointer;
    color: var(--gold);
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .variant-nav:hover { border-color: var(--gold); background: var(--gold); color: #0c0c0c; }

  .variant-svg-wrap {
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    padding: 12px;
    display: flex;
    justify-content: center;
  }
  .panel-svg { display: block; margin: 0 auto; max-width: 100%; }

  .variant-dims {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.88rem;
    color: var(--text-muted);
  }
  .variant-dims b { color: #ccc; }

  .price-line { font-size: 1rem; color: var(--text-muted); }
  .price-line s { color: #444; font-size: 0.9rem; }
  .price-final { font-size: 1.4rem; font-weight: 700; color: var(--gold); margin-left: 8px; }
  .discount-badge {
    display: inline-block;
    padding: 2px 8px;
    background: rgba(201,168,76,0.1);
    color: var(--gold);
    border-radius: 4px;
    font-size: 0.82rem;
    font-weight: 700;
