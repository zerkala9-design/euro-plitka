---
import { tileCalcConfig } from '../data/site';
const cfg = JSON.stringify(tileCalcConfig);
---

<section class="calc-section section">
  <div class="container">
    <h2 class="calc-title">Калькулятор дзеркального панно</h2>
    <p class="calc-sub">Введіть розміри вашої стіни — отримайте варіанти розкрою та вартість</p>

    <div class="calc-inputs">
      <label class="calc-field">
        <span class="calc-field__label">Ширина</span>
        <input type="number" id="wallW" value="1500" min="300" max="5000" step="10" />
        <span class="calc-field__unit">мм</span>
      </label>
      <label class="calc-field">
        <span class="calc-field__label">Висота</span>
        <input type="number" id="wallH" value="2700" min="300" max="5000" step="10" />
        <span class="calc-field__unit">мм</span>
      </label>
      <label class="calc-field">
        <span class="calc-field__label">Фацет</span>
        <select id="facet">
          <option value="1">0 мм</option>
          <option value="2">5 мм</option>
          <option value="3" selected>10 мм</option>
          <option value="4">15 мм</option>
          <option value="5">20 мм</option>
        </select>
      </label>
      <label class="calc-field calc-field--color">
        <span class="calc-field__label">Колір</span>
        <select id="color">
          <option value="1">Срібло</option>
          <option value="2">Бронза</option>
          <option value="3">Графіт</option>
        </select>
        <span class="calc-field__swatch" id="colorSwatch"></span>
      </label>
    </div>

    <div class="calc-panels" id="calcPanels">
      <!-- cut -->
      <div class="calc-panel" id="panel-cut">
        <div class="panel-header">
          <span class="panel-mode">Розкрій квадратами</span>
        </div>
        <div class="panel-preview">
          <svg class="panel-svg" id="svg-cut" xmlns="http://www.w3.org/2000/svg"></svg>
          <div class="panel-cutted" id="cutted-cut"></div>
        </div>
        <div class="panel-zoom">
          <button class="zoom-btn" id="reset-cut" title="Скинути">↺</button>
          <button class="zoom-btn" id="zoom-in-cut" title="Збільшити плитку">−</button>
          <button class="zoom-btn" id="zoom-out-cut" title="Зменшити плитку">+</button>
        </div>
        <div class="panel-info" id="info-cut"></div>
        <div class="panel-price" id="price-cut"></div>
        <button class="btn btn--primary panel-order" data-mode="cut">🛒 Замовити</button>
      </div>

      <!-- fit -->
      <div class="calc-panel" id="panel-fit">
        <div class="panel-header">
          <span class="panel-mode">Розкрій ромбами</span>
        </div>
        <div class="panel-preview">
          <svg class="panel-svg" id="svg-fit" xmlns="http://www.w3.org/2000/svg"></svg>
        </div>
        <div class="panel-zoom">
          <button class="zoom-btn" id="reset-fit" title="Скинути">↺</button>
          <button class="zoom-btn" id="zoom-in-fit" title="Збільшити плитку">−</button>
          <button class="zoom-btn" id="zoom-out-fit" title="Зменшити плитку">+</button>
        </div>
        <div class="panel-info" id="info-fit"></div>
        <div class="panel-price" id="price-fit"></div>
        <button class="btn btn--primary panel-order" data-mode="fit">🛒 Замовити</button>
      </div>
    </div>

    <!-- Модалка замовлення -->
    <div class="order-modal" id="orderModal">
      <div class="order-modal__box">
        <button class="order-modal__close" id="closeModal">✕</button>
        <h3 id="modalTitle">Дзеркальне панно</h3>
        <table class="order-table" id="orderTable"></table>
        <div class="order-modal__form">
          <input type="text" placeholder="Ім'я та Прізвище" class="order-modal__input" id="modalName" />
          <input type="tel" placeholder="Телефон" class="order-modal__input" id="modalPhone" />
          <button class="btn btn--primary" id="submitOrder" style="width:100%">Відправити замовлення</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ cfg }}>
const CFG = JSON.parse(cfg);
const MODES = ['cut', 'fit'];
const customCols = { cut: 0, fit: 0 };
const panelData = {};

// Кольори превʼю панно за кольором дзеркала (як в оригіналі)
const TILE_THEME = {
  1: { c1: '#f2f2f2', c2: '#c8c8c8', line: '#9a9a9a' }, // Серебро
  2: { c1: '#f0e0b0', c2: '#d4a84b', line: '#a9821f' }, // Бронза
  3: { c1: '#d6d6d6', c2: '#8f8f8f', line: '#5a5a5a' }, // Графіт
};

// --- Ціна (з app.js) ---
function areaPrice(color) {
  return Number(color) === 1 ? CFG.silverPrice : CFG.colorPrice;
}

function facetPrice(facet) {
  return CFG.facetsPrices[Number(facet) - 1] || 0;
}

function calcPrice(row) {
  const w = row.width, h = row.height, qty = row.quantity;
  let form = row.form;
  if (row.triangle) form *= CFG.trianglePrice;
  const ap = areaPrice(row.color);
  const fp = facetPrice(row.facet);
  return Math.round((w * h * 1e-6 * ap + (2 * w + 2 * h) * 0.001 * fp) * form * qty * CFG.defaultPrice * CFG.extraPrice);
}

// --- Осі (з app.js) ---
function calcAxisX(input, customC) {
  const X = {};
  X.size = Number((input.width / 10).toFixed(2));
  X.grid = Math.round(X.size / (CFG.gridAuto / 10)) + customC;
  X.tile = X.size / X.grid;
  return X;
}

function calcAxisY(input) {
  const Y = {};
  Y.size = Number((input.height / 10).toFixed(2));
  Y.grid = Math.round(Y.size / (CFG.gridAuto / 10));
  Y.tile = Y.size / Y.grid;
  return Y;
}

// --- Генерація панелі (з app.js generatePanel) ---
function generatePanel(mode, input, customC) {
  const X = calcAxisX(input, customC);
  const Y = calcAxisY(input);

  if (mode === 'fit') {
    X.tile = X.size / X.grid;
    Y.tile = Y.size / Y.grid;
    const ratio = Y.tile / X.tile;
    if (ratio < CFG.gridRatio.ideal || ratio > CFG.gridRatio.max) {
      Y.tile = X.tile * CFG.gridRatio.ideal;
      Y.grid = Y.size / Y.tile;
      Y.tile = Y.size / Math.ceil(Y.grid);
    }
  }

  if (mode === 'cover' || mode === 'cut') {
    X.tile = Y.tile = X.size / X.grid;
    Y.grid = Math.floor(Y.size / X.tile);
    if (mode === 'cover') {
      Y.covered = Y.size - X.tile * Y.grid;
    }
    if (mode === 'cut') {
      const cutLine = X.tile * Y.grid;
      const remainder = Y.size - cutLine;
      const halfTile = Math.ceil(X.tile / 2);
      let finalLine = cutLine;
      if (remainder >= halfTile) finalLine = cutLine + halfTile;
      Y.sizeO = Y.size;
      Y.size = Number(finalLine.toFixed(0));
      Y.cutted = Y.sizeO - Y.size;
    }
  }

  return { mode, input, X, Y };
}

// --- Генерація рядків (з app.js generateRows) ---
function generateRows(panel) {
  const { X, Y } = panel;
  const d1 = 10 * X.tile; // діагональ X у мм
  const d2 = 10 * Y.tile; // діагональ Y у мм
  const tileSide = Math.sqrt((d1 / 2) ** 2 + (d2 / 2) ** 2); // сторона ромба у мм

  const cols = Math.round(X.size / X.tile);
  const rowCount = Math.round(Y.size / Y.tile);
  const r = Y.size / Y.tile;

  let c = (cols - 1) * rowCount + (rowCount - 1) * cols; // цілі плитки
  let u = 2 * (cols + rowCount);                          // крайові трикутники
  let d = 0, p = 0, m = 0;

  if (panel.mode === 'cover' && r > rowCount) {
    const v = Number((r - rowCount).toFixed(2));
    if (v < 0.5) c += cols;
  }

  if (panel.mode === 'cut') {
    const h = Math.round(10 * r) / 10;
    if (rowCount - h > 0) { c -= cols - 1; u -= 3; m = 2; }
  }

  const f = (Math.abs(X.tile - Y.tile) < 0.001) ? 1 : 1.3;

  if (panel.mode === 'fit' && Math.abs(X.tile - Y.tile) >= 0.001) {
    u = 0;
    d = 2 * cols;
    p = 2 * rowCount;
  }

  const colorVal = Number(panel.input.color);
  const facetVal = Number(panel.input.facet);
  const rows = [];

  function addRow(qty, isTri, w, h, form) {
    if (!qty) return;
    const row = { form, triangle: isTri, width: w, height: h, facet: facetVal, color: colorVal, quantity: qty };
    row.price = calcPrice(row);
    rows.push(row);
  }

  const sw = Math.round(tileSide);
  const halfSide = Number((d1 / 2).toFixed(0));

  addRow(c, false, sw, sw, f);
  addRow(u, true,  sw, sw, f);
  addRow(d, true,  sw, sw, f);
  addRow(p, true,  sw, sw, f);
  addRow(m, true,  halfSide, halfSide, f);

  let total = rows.reduce((s, r) => s + r.price, 0);

  // Фіксована ціна за м² за кольором (квадрати / ромби):
  //   Срібло — 3000 / 3600;  Бронза, Графіт — 4200 / 4800.
  // Націнка за фацет: 15мм → +10%, 20мм → ще +10% (×1.21).
  {
    const RATES = {
      1: { cut: 3000, fit: 3600 }, // срібло
      2: { cut: 4200, fit: 4800 }, // бронза
      3: { cut: 4200, fit: 4800 }, // графіт
    };
    const r = RATES[Number(panel.input.color)] || RATES[1];
    const areaM2 = (panel.input.width / 1000) * (panel.input.height / 1000);
    const rate = panel.mode === 'fit' ? r.fit : r.cut;
    const facetV = Number(panel.input.facet); // 4 = 15мм, 5 = 20мм
    const facetMult = facetV === 4 ? 1.10 : facetV === 5 ? 1.21 : 1;
    total = Math.round(areaM2 * rate * facetMult);
  }

  return {
    rows,
    total,
    tileSize: sw,
    d1: Math.round(d1),
    d2: Math.round(d2),
    cols,
    rowCount,
    isSquare: f === 1,
  };
}

// --- SVG малювання (діагональна сітка, як в оригіналі) ---
function drawPanel(mode, panel, info) {
  const svgEl = document.getElementById('svg-' + mode);
  const { X, Y } = panel;

  const MAX_W = 380, MAX_H = 360;
  const ratio = Y.size / X.size;
  let dW, dH;
  if (ratio > MAX_H / MAX_W) {
    dH = MAX_H; dW = dH / ratio;
  } else {
    dW = MAX_W; dH = dW * ratio;
  }
  dW = Math.round(dW); dH = Math.round(dH);

  const MARGIN_TOP = 30, MARGIN_RIGHT = 34;
  const VW = dW + MARGIN_RIGHT + 4;
  const VH = dH + MARGIN_TOP + 4;

  svgEl.setAttribute('viewBox', `0 0 ${VW} ${VH}`);
  svgEl.style.width = VW + 'px';
  svgEl.style.height = VH + 'px';

  const ox = 2, oy = MARGIN_TOP;
  const scaleX = dW / X.size;
  const scaleY = dH / Y.size;
  const tW = X.tile * scaleX;
  const tH = Y.tile * scaleY;

  // Малюємо діагональні лінії у кожній клітинці (як оригінал)
  let lines = '';
  const cols = Math.ceil(X.size / X.tile) + 1;
  const rows = Math.ceil(Y.size / Y.tile) + 1;
  for (let n = 0; n <= rows; n++) {
    for (let r = 0; r <= cols; r++) {
      const x0 = ox + r * tW, y0 = oy + n * tH;
      const x1 = ox + (r + 1) * tW, y1 = oy + (n + 1) * tH;
      lines += `<line x1="${x0.toFixed(1)}" y1="${y0.toFixed(1)}" x2="${x1.toFixed(1)}" y2="${y1.toFixed(1)}" />`;
      lines += `<line x1="${x0.toFixed(1)}" y1="${y1.toFixed(1)}" x2="${x1.toFixed(1)}" y2="${y0.toFixed(1)}" />`;
    }
  }

  const clipId = 'cl-' + mode;
  const gradId = 'gr-' + mode;
  const fs = 13;
  const dimColor = '#9a7420';

  // Колір превʼю за обраним кольором дзеркала
  const theme = TILE_THEME[Number(panel.input.color)] || TILE_THEME[1];

  // Cutted (cut-режим): смуга знизу яка відрізається
  let cuttedRect = '';
  if (mode === 'cut' && Y.cutted) {
    const cutPx = Y.cutted * scaleY;
    cuttedRect = `<rect x="${ox}" y="${oy + dH}" width="${dW}" height="${cutPx.toFixed(1)}" fill="rgba(80,80,80,0.22)" stroke="#888" stroke-width="0.8"/>`;
  }

  svgEl.innerHTML = `
    <defs>
      <clipPath id="${clipId}">
        <rect x="${ox}" y="${oy}" width="${dW}" height="${dH}" />
      </clipPath>
      <linearGradient id="${gradId}" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="${theme.c1}"/>
        <stop offset="55%" stop-color="${theme.c2}"/>
        <stop offset="100%" stop-color="${theme.c1}"/>
      </linearGradient>
    </defs>
    <rect x="${ox}" y="${oy}" width="${dW}" height="${dH}" fill="url(#${gradId})" />
    <g clip-path="url(#${clipId})" stroke="${theme.line}" stroke-width="0.9" opacity="0.8">${lines}</g>
    ${cuttedRect}
    <rect x="${ox}" y="${oy}" width="${dW}" height="${dH}" fill="none" stroke="${theme.line}" stroke-width="1.8"/>
    <line x1="${ox}" y1="${oy-12}" x2="${ox+dW}" y2="${oy-12}" stroke="${dimColor}" stroke-width="1.4"/>
    <line x1="${ox}" y1="${oy-17}" x2="${ox}" y2="${oy-6}" stroke="${dimColor}" stroke-width="1.4"/>
    <line x1="${ox+dW}" y1="${oy-17}" x2="${ox+dW}" y2="${oy-6}" stroke="${dimColor}" stroke-width="1.4"/>
    <text x="${ox+dW/2}" y="${oy-15}" text-anchor="middle" font-size="${fs}" fill="${dimColor}" font-family="Inter,Arial,sans-serif" font-weight="700">${panel.input.width} мм</text>
    <line x1="${ox+dW+12}" y1="${oy}" x2="${ox+dW+12}" y2="${oy+dH}" stroke="${dimColor}" stroke-width="1.4"/>
    <line x1="${ox+dW+6}" y1="${oy}" x2="${ox+dW+18}" y2="${oy}" stroke="${dimColor}" stroke-width="1.4"/>
    <line x1="${ox+dW+6}" y1="${oy+dH}" x2="${ox+dW+18}" y2="${oy+dH}" stroke="${dimColor}" stroke-width="1.4"/>
    <text x="${ox+dW+16}" y="${oy+dH/2}" text-anchor="middle" font-size="${fs}" fill="${dimColor}" font-family="Inter,Arial,sans-serif" font-weight="700" transform="rotate(90,${ox+dW+16},${oy+dH/2})">${panel.input.height} мм</text>
  `;
}

// --- Відображення інфо та ціни ---
function fmt(n) { return n.toLocaleString('uk-UA') + ' грн'; }

function updatePanelUI(mode, panel, rowData) {
  const colorNames = ['', 'срібло', 'бронза', 'графіт'];
  const facetNames = ['', '0', '5', '10', '15', '20'];

  document.getElementById('info-' + mode).innerHTML = `
    <span>Плитка: <b>${rowData.tileSize}×${rowData.tileSize} мм</b></span>
    <span>Діагоналі: <b>${rowData.d1}×${rowData.d2} мм</b></span>
    <span>Сітка: <b>${rowData.cols}×${rowData.rowCount}</b></span>
  `;

  document.getElementById('price-' + mode).innerHTML = `
    <span class="price-label">Ціна:</span> <span class="price-total">${fmt(rowData.total)}</span>
  `;

  // Зберігаємо для модалки
  panelData[mode] = { panel, rowData, colorName: colorNames[Number(panel.input.color)] || 'срібло', facetName: facetNames[Number(panel.input.facet)] || '10' };
}

// --- Головний рендер ---
function getInput() {
  return {
    width:  Math.max(300, Math.min(5000, parseInt(document.getElementById('wallW').value) || 1500)),
    height: Math.max(300, Math.min(5000, parseInt(document.getElementById('wallH').value) || 2700)),
    facet:  Number(document.getElementById('facet').value),
    color:  Number(document.getElementById('color').value),
  };
}

function renderAll() {
  const input = getInput();
  MODES.forEach(mode => {
    const panel = generatePanel(mode, input, customCols[mode]);
    const rowData = generateRows(panel);
    drawPanel(mode, panel, rowData);
    updatePanelUI(mode, panel, rowData);
    checkZoomLimits(mode, input);
  });
}

// Розмір плитки (діагональна сторона, мм), що буде показано при заданому customC
function tileSizeFor(mode, input, customC) {
  const grid = Math.round((input.width / 10) / (CFG.gridAuto / 10)) + customC;
  if (grid < 1) return Infinity; // занадто велика плитка — заборонено
  const panel = generatePanel(mode, input, customC);
  return generateRows(panel).tileSize;
}

function checkZoomLimits(mode, input) {
  // обмеження саме за показаним розміром плитки: 200…600 мм
  const smaller = tileSizeFor(mode, input, customCols[mode] + 1); // − зробити дрібніше
  const bigger  = tileSizeFor(mode, input, customCols[mode] - 1); // + зробити крупніше
  document.getElementById('zoom-out-' + mode).disabled = smaller < CFG.tileMin;
  document.getElementById('zoom-in-' + mode).disabled  = bigger > CFG.tileMax;
  document.getElementById('reset-' + mode).disabled = customCols[mode] === 0;
}

// --- Кнопки зуму ---
MODES.forEach(mode => {
  // зменшити плитку (більше плиток)
  document.getElementById('zoom-out-' + mode).addEventListener('click', () => {
    const input = getInput();
    if (tileSizeFor(mode, input, customCols[mode] + 1) >= CFG.tileMin) {
      customCols[mode]++;
      renderAll();
    }
  });
  // збільшити плитку (менше плиток)
  document.getElementById('zoom-in-' + mode).addEventListener('click', () => {
    const input = getInput();
    if (tileSizeFor(mode, input, customCols[mode] - 1) <= CFG.tileMax) {
      customCols[mode]--;
      renderAll();
    }
  });
  document.getElementById('reset-' + mode).addEventListener('click', () => {
    customCols[mode] = 0;
    renderAll();
  });
});

// --- Модалка ---
function openModal(mode) {
  const { panel, rowData, colorName, facetName } = panelData[mode] || {};
  if (!rowData) return;

  const modeNames = { cover: 'з перекриттям', cut: 'з підрізкою', fit: 'підгонка' };
  document.getElementById('modalTitle').textContent =
    `Панно ${panel.input.width}×${panel.input.height} мм (${modeNames[mode]})`;

  const formNames = { 1: 'квадрат', 1.3: 'ромб' };
  const rows = rowData.rows.map(r => {
    const fName = r.triangle ? 'трикутник' : (formNames[r.form] || 'квадрат');
    return `<tr>
      <td>${fName}</td>
      <td>${r.width}×${r.height}</td>
      <td>${facetName} мм</td>
      <td>${colorName}</td>
      <td>${r.quantity} шт.</td>
      <td><b>${fmt(r.price)}</b></td>
    </tr>`;
  }).join('');

  document.getElementById('orderTable').innerHTML = `
    <thead><tr><th>Форма</th><th>Розмір</th><th>Фацет</th><th>Колір</th><th>К-во</th><th>Ціна</th></tr></thead>
    <tbody>${rows}<tr class="order-total"><td colspan="4">Всього</td><td colspan="2"><b>${fmt(rowData.total)}</b></td></tr></tbody>
  `;
  document.getElementById('orderModal').classList.add('open');
}

document.querySelectorAll('.panel-order').forEach(btn => {
  btn.addEventListener('click', () => openModal(btn.dataset.mode));
});
document.getElementById('closeModal').addEventListener('click', () =>
  document.getElementById('orderModal').classList.remove('open')
);
document.getElementById('orderModal').addEventListener('click', e => {
  if (e.target === document.getElementById('orderModal'))
    document.getElementById('orderModal').classList.remove('open');
});

document.getElementById('submitOrder').addEventListener('click', () => {
  const name = document.getElementById('modalName').value.trim();
  const phone = document.getElementById('modalPhone').value.trim();
  if (!name || !phone) { alert("Будь ласка, вкажіть ім'я та телефон"); return; }
  alert('Дякуємо! Ми зв\'яжемося з вами найближчим часом.');
  document.getElementById('orderModal').classList.remove('open');
});

// --- Колір swatch ---
const swatchColors = { 1: '#c0c0c0', 2: '#cd7f32', 3: '#555' };
const colorSel = document.getElementById('color');
const swatch = document.getElementById('colorSwatch');
const updateSwatch = () => { swatch.style.background = swatchColors[colorSel.value] || '#c0c0c0'; };
colorSel.addEventListener('change', updateSwatch);
updateSwatch();

// --- Inputs ---
let debounce;
['wallW', 'wallH'].forEach(id => {
  document.getElementById(id).addEventListener('input', () => {
    clearTimeout(debounce);
    debounce = setTimeout(renderAll, 400);
  });
  document.getElementById(id).addEventListener('change', renderAll);
});
['facet', 'color'].forEach(id =>
  document.getElementById(id).addEventListener('change', renderAll)
);

// Ініціалізація
renderAll();
</script>

<style>
  .calc-section { background: var(--bg-gray); padding: 80px 0; }
  .calc-title { margin-bottom: 6px; color: var(--text); font-family: var(--font-heading); }
  .calc-sub { color: var(--text-muted); margin-bottom: 28px; }

  .calc-inputs {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .calc-field {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 14px;
    cursor: pointer;
    transition: border-color 0.2s;
    min-width: 160px;
    flex: 1;
  }
  .calc-field:focus-within { border-color: var(--gold); }
  .calc-field__label { font-size: 0.95rem; font-weight: 600; color: var(--text-mid); white-space: nowrap; }
  .calc-field input, .calc-field select {
    flex: 1;
    border: none;
    outline: none;
    font-family: var(--font);
    font-size: 1rem;
    font-weight: 600;
    background: transparent;
    color: var(--text);
    min-width: 50px;
  }
