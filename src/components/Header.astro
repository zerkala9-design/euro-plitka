---
import { site, nav } from '../data/site';
const current = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="container header__inner">
    <a href="/" class="logo">
      <span class="logo__euro">Euro</span><span class="logo__plitka">Plitka</span>
    </a>

    <nav class="nav" aria-label="Головне меню">
      <ul class="nav__list">
        {nav.map((item) => (
          <li>
            <a
              href={item.path}
              class:list={['nav__link', { active: current === item.path || (item.path !== '/' && current.startsWith(item.path)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__contacts">
      <a href={`tel:${site.phone.tel}`} class="header__phone">{site.phone.display}</a>
      <a href={site.social.telegram} class="btn btn--primary" target="_blank" rel="noopener">Telegram</a>
    </div>

    <button class="burger" id="burger" aria-label="Меню" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobileNav">
    <ul>
      {nav.map((item) => (
        <li><a href={item.path} class="mobile-nav__link">{item.label}</a></li>
      ))}
    </ul>
    <div class="mobile-nav__footer">
      <a href={`tel:${site.phone.tel}`} class="mobile-nav__phone">{site.phone.display}</a>
      <a href={site.social.telegram} class="btn btn--primary" target="_blank" rel="noopener" style="width:100%;text-align:center">Telegram</a>
    </div>
  </div>
</header>

<script>
  const burger = document.getElementById('burger');
  const mobileNav = document.getElementById('mobileNav');
  burger?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    burger.classList.toggle('open', !!open);
  });
  // close on link click
  mobileNav?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileNav.classList.remove('open');
      burger?.classList.remove('open');
    });
  });
  // scroll shadow
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 10);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    transition: box-shadow 0.2s;
  }
  .header.scrolled { box-shadow: 0 2px 24px rgba(26,24,20,0.1); }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 28px;
    height: 70px;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }
  .logo__euro { color: var(--gold); }
  .logo__plitka { color: var(--text); }

  .nav { flex: 1; }
  .nav__list { display: flex; gap: 2px; list-style: none; }
  .nav__link {
    display: block;
    padding: 6px 12px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    color: var(--text-mid);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .nav__link:hover { color: var(--gold); background: var(--gold-pale); }
  .nav__link.active { color: var(--gold); font-weight: 600; }

  .header__contacts { display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
  .header__phone {
    font-weight: 700;
    font-size: 0.95rem;
    white-space: nowrap;
    color: var(--text);
    transition: color 0.15s;
  }
  .header__phone:hover { color: var(--gold); }
  .header__contacts .btn { font-size: 0.875rem; padding: 10px 20px; }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 6px;
    flex-shrink: 0;
    margin-left: auto;
  }
  .burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    transition: all 0.3s;
    border-radius: 2px;
  }
  .burger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .burger.open span:nth-child(2) { opacity: 0; }
  .burger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  .mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--white);
    border-top: 1px solid var(--border);
    padding: 8px 20px 24px;
    box-shadow: 0 8px 32px rgba(26,24,20,0.1);
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav ul { list-style: none; display: flex; flex-direction: column; }
  .mobile-nav__link {
    display: block;
    padding: 12px 8px;
    font-weight: 500;
    color: var(--text-mid);
    border-bottom: 1px solid var(--border);
    transition: color 0.15s;
  }
  .mobile-nav__link:hover { color: var(--gold); }
  .mobile-nav__footer { margin-top: 20px; display: flex; flex-direction: column; gap: 12px; }
  .mobile-nav__phone { font-weight: 700; font-size: 1.15rem; color: var(--text); }

  @media (max-width: 1024px) {
    .nav { display: none; }
    .header__contacts { display: none; }
    .burger { display: flex; }
  }
</style>
