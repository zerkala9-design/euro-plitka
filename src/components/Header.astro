---
import { site, nav } from '../data/site';
const current = Astro.url.pathname;
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="logo">
      <span class="logo__euro">Euro</span><span class="logo__plitka">Plitka</span>
    </a>

    <nav class="nav" aria-label="Головне меню">
      <ul class="nav__list">
        {nav.map((item) => (
          <li>
            <a
              href={item.path}
              class:list={['nav__link', { active: current === item.path || (item.path !== '/' && current.startsWith(item.path)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__contacts">
      <a href={`tel:${site.phone.tel}`} class="header__phone">{site.phone.display}</a>
      <a href={`https://t.me/${site.social.telegram.split('/').pop()}`} class="btn btn--primary btn__telegram" target="_blank">
        Telegram
      </a>
    </div>

    <button class="burger" id="burger" aria-label="Меню" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobileNav">
    <ul>
      {nav.map((item) => (
        <li><a href={item.path} class="mobile-nav__link">{item.label}</a></li>
      ))}
    </ul>
    <a href={`tel:${site.phone.tel}`} class="mobile-nav__phone">{site.phone.display}</a>
  </div>
</header>

<script>
  const burger = document.getElementById('burger');
  const mobileNav = document.getElementById('mobileNav');
  burger?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    burger.classList.toggle('open', !!open);
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(12,12,12,0.96);
    border-bottom: 1px solid rgba(201,168,76,0.2);
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }
  .header__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 68px;
  }
  .logo {
    font-size: 1.4rem;
    font-weight: 800;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }
  .logo__euro { color: var(--gold); }
  .logo__plitka { color: var(--text); }

  .nav { flex: 1; }
  .nav__list { display: flex; gap: 2px; flex-wrap: wrap; }
  .nav__link {
    display: block;
    padding: 6px 10px;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 4px;
    color: var(--text-muted);
    transition: color 0.2s;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .nav__link:hover, .nav__link.active { color: var(--gold); }
  .nav__link.active { background: rgba(201,168,76,0.08); }

  .header__contacts { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .header__phone { font-weight: 700; font-size: 0.95rem; white-space: nowrap; color: var(--text); }
  .header__phone:hover { color: var(--gold); }
  .btn__telegram { font-size: 0.85rem; padding: 8px 16px; }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }
  .burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    transition: all 0.3s;
    border-radius: 2px;
  }
  .burger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .burger.open span:nth-child(2) { opacity: 0; }
  .burger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  .mobile-nav {
    display: none;
    flex-direction: column;
    background: #0f0f0f;
    border-top: 1px solid var(--border);
    padding: 16px 20px 24px;
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav ul { display: flex; flex-direction: column; gap: 4px; }
  .mobile-nav__link {
    display: block;
    padding: 10px 12px;
    font-weight: 600;
    border-radius: 6px;
    color: var(--text-muted);
  }
  .mobile-nav__link:hover { background: var(--bg-card); color: var(--gold); }
  .mobile-nav__phone { margin-top: 16px; font-weight: 700; font-size: 1.1rem; color: var(--gold); }

  @media (max-width: 960px) {
    .nav { display: none; }
    .header__contacts { display: none; }
    .burger { display: flex; margin-left: auto; }
  }
</style>
