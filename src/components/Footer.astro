---
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__top">
    <div class="container footer__grid">
      <div class="footer__brand">
        <a href="/" class="logo">
          <span class="logo__euro">Euro</span><span class="logo__plitka">Plitka</span>
        </a>
        <p>Дзеркальна плитка та LED дзеркала в Києві. Виготовлення та монтаж від виробника.</p>
        <div class="footer__socials">
          {site.social.instagram && (
            <a href={site.social.instagram} target="_blank" rel="noopener">Instagram</a>
          )}
          {site.social.telegram && (
            <a href={site.social.telegram} target="_blank" rel="noopener">Telegram</a>
          )}
        </div>
      </div>

      <div>
        <h4>Навігація</h4>
        <ul>
          {nav.map((item) => (
            <li><a href={item.path}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4>Калькулятори</h4>
        <ul>
          <li><a href="/">Калькулятор панно</a></li>
          <li><a href="/led-dzerkalo/">Калькулятор LED дзеркала</a></li>
        </ul>
        <h4 style="margin-top:1.5rem">Контакти</h4>
        <ul class="footer__contacts">
          <li><a href={`tel:${site.phone.tel}`}>{site.phone.display}</a></li>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li>{site.address}</li>
          <li>{site.workingHours}</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container footer__bottom">
    <span>© {year} {site.name}. Всі права захищені.</span>
  </div>
</footer>

<style>
  .footer {
    background: #080808;
    border-top: 1px solid rgba(201,168,76,0.15);
    margin-top: 80px;
    color: #666;
  }
  .footer__top { padding: 56px 0 48px; }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 48px;
  }
  .footer h4 {
    color: var(--gold);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 1rem;
  }
  .footer ul { display: flex; flex-direction: column; gap: 10px; }
  .footer a { color: #666; font-size: 0.9rem; transition: color 0.2s; }
  .footer a:hover { color: var(--gold); }
  .logo { font-size: 1.3rem; font-weight: 800; display: block; margin-bottom: 14px; letter-spacing: -0.02em; }
  .logo__euro { color: var(--gold); }
  .logo__plitka { color: #e0e0e0; }
  .footer__brand p { font-size: 0.9rem; line-height: 1.7; max-width: 30ch; color: #555; }
  .footer__socials { display: flex; gap: 16px; margin-top: 20px; }
  .footer__socials a { font-weight: 700; color: #888; }
  .footer__contacts a { font-weight: 600; color: #888; }
  .footer__bottom {
    border-top: 1px solid #1a1a1a;
    padding: 20px 20px;
    font-size: 0.82rem;
    color: #333;
  }
  @media (max-width: 768px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1/-1; }
  }
  @media (max-width: 480px) { .footer__grid { grid-template-columns: 1fr; } }
</style>
