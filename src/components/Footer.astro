---
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__top">
    <div class="container footer__grid">
      <div class="footer__brand">
        <a href="/" class="logo">
          <span class="logo__euro">Euro</span><span class="logo__plitka">Plitka</span>
        </a>
        <p>Дзеркальна плитка та LED дзеркала в Києві. Виготовлення панно та монтаж від виробника.</p>
        <div class="footer__socials">
          {site.social.instagram && (
            <a href={site.social.instagram} target="_blank" rel="noopener" class="social-link">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              Instagram
            </a>
          )}
          {site.social.telegram && (
            <a href={site.social.telegram} target="_blank" rel="noopener" class="social-link">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              Telegram
            </a>
          )}
        </div>
      </div>

      <div class="footer__col">
        <h4>Каталог</h4>
        <ul>
          {nav.slice(1, 5).map((item) => (
            <li><a href={item.path}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4>Компанія</h4>
        <ul>
          {nav.slice(5).map((item) => (
            <li><a href={item.path}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4>Контакти</h4>
        <ul class="footer__contacts">
          <li><a href={`tel:${site.phone.tel}`}>{site.phone.display}</a></li>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li>{site.address}</li>
          <li>{site.workingHours}</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <span>© {year} {site.name}. Всі права захищені.</span>
      <span>Дзеркальна плитка в Києві</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-dark);
    color: #888;
    margin-top: 0;
  }
  .footer__top { padding: 72px 0 56px; }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1.2fr;
    gap: 48px;
  }
  .footer h4 {
    color: var(--gold);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 18px;
  }
  .footer ul { list-style: none; display: flex; flex-direction: column; gap: 11px; }
  .footer a { color: #888; font-size: 0.9rem; transition: color 0.15s; }
  .footer a:hover { color: var(--gold-light); }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    display: inline-block;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .logo__euro { color: var(--gold); }
  .logo__plitka { color: #e0e0e0; }

  .footer__brand p { font-size: 0.9rem; line-height: 1.75; max-width: 28ch; color: #666; margin-bottom: 24px; }
  .footer__socials { display: flex; gap: 14px; flex-wrap: wrap; }
  .social-link {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 14px;
    border: 1px solid #2a2820;
    border-radius: var(--radius-sm);
    font-size: 0.85rem; font-weight: 600; color: #888;
    transition: all 0.15s;
  }
  .social-link:hover { border-color: var(--gold); color: var(--gold) !important; background: rgba(184,144,58,0.08); }

  .footer__contacts li { color: #666; font-size: 0.9rem; }
  .footer__contacts a { font-weight: 600; }

  .footer__bottom {
    border-top: 1px solid #222;
    padding: 20px 0;
  }
  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
    color: #444;
    flex-wrap: wrap;
    gap: 8px;
  }

  @media (max-width: 1024px) {
    .footer__grid { grid-template-columns: 1.5fr 1fr 1fr; }
    .footer__brand { grid-column: 1/-1; }
    .footer__brand p { max-width: 100%; }
  }
  @media (max-width: 640px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer__top { padding: 48px 0 40px; }
  }
  @media (max-width: 400px) {
    .footer__grid { grid-template-columns: 1fr; }
  }
</style>
